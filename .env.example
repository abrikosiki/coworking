# Ключи для подключения к Supabase
# Эти переменные нужно прописать в настройках хостинга (Render.com, Vercel, и т.д.)
# В GoDaddy настраиваются только DNS-записи домена.

# 1. Основные API-ключи (Dashboard → проект → Settings → API)
# Project URL
SUPABASE_URL=your_supabase_project_url

# anon public (для клиента, с RLS)
SUPABASE_ANON_KEY=your_supabase_anon_key

# service_role (только для сервера, не светить в браузере)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 2. Прямой доступ к БД (Settings → Database → Connection string (URI))
SUPABASE_DB_URL=your_supabase_db_connection_string
# Или
DATABASE_URL=your_supabase_db_connection_string
